# =============================================================================
# AI Chatbot with Memory - Environment Configuration
# =============================================================================
#
# This file configures which APIs to use.
# 
# FREE SETUP (Recommended for students):
#   LLM_PROVIDER=groq
#   EMBEDDING_PROVIDER=huggingface
#   GROQ_API_KEY=your_free_groq_key
#
# 100% FREE LOCAL SETUP:
#   LLM_PROVIDER=ollama
#   EMBEDDING_PROVIDER=huggingface
#   (No API keys needed!)
# =============================================================================

# =============================================================================
# STEP 1: CHOOSE YOUR LLM PROVIDER
# =============================================================================

# Options: "groq", "ollama", "openai"
# DEFAULT: "groq" (FREE and fast!)
LLM_PROVIDER=groq

# =============================================================================
# STEP 2: CHOOSE YOUR EMBEDDING PROVIDER
# =============================================================================

# Options: "huggingface" (FREE), "openai" (paid)
# DEFAULT: "huggingface" (completely free!)
EMBEDDING_PROVIDER=huggingface

# =============================================================================
# STEP 3: CONFIGURE API KEYS (Based on your choices above)
# =============================================================================

# --- FOR GROQ (FREE - Recommended!) ---
# Get FREE API key: https://console.groq.com/keys
# Free tier: 1,000,000 tokens per day!
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: Choose Groq model
# Options: "llama3-8b-8192" (fast), "llama3-70b-8192" (better), "mixtral-8x7b-32768"
# GROQ_MODEL=llama3-8b-8192

# --- FOR OLLAMA (100% FREE - Local) ---
# No API key needed! Just install Ollama.
# Download: https://ollama.com/download
# Then run: ollama pull llama3.2
# Then run: ollama serve

# Optional: Ollama settings
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- FOR OPENAI (Paid - Optional) ---
# Only needed if using OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here

# =============================================================================
# HOW TO GET FREE GROQ API KEY
# =============================================================================
#
# 1. Go to https://console.groq.com/
# 2. Sign up with email or GitHub (free!)
# 3. Click "API Keys" in the left sidebar
# 4. Click "Create API Key"
# 5. Copy the key (starts with "gsk_")
# 6. Paste it above as GROQ_API_KEY=gsk_your_key
#
# FREE TIER LIMITS:
# - 1,000,000 tokens per day
# - 20 requests per minute
# - More than enough for a semester project!
#
# COST: $0 (completely free!)
# =============================================================================

# =============================================================================
# HOW TO SETUP OLLAMA (100% FREE - NO INTERNET NEEDED)
# =============================================================================
#
# 1. Download Ollama: https://ollama.com/download
# 2. Install it (follow instructions for your OS)
# 3. Open terminal and run:
#    ollama pull llama3.2
# 4. Start the server:
#    ollama serve
# 5. Set LLM_PROVIDER=ollama in this file
# 6. Run the chatbot!
#
# DOWNLOAD SIZE: ~2GB for llama3.2 model
# COST: $0 forever (runs on your computer!)
# =============================================================================

# =============================================================================
# HUGGINGFACE EMBEDDINGS (FREE - No setup needed!)
# =============================================================================
#
# HuggingFace embeddings are completely FREE!
# - No API key required
# - Downloads model once (~80MB)
# - Runs locally on your CPU
# - Works offline after first download
#
# Optional: Change the embedding model
# HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# =============================================================================
